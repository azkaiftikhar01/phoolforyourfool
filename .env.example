# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Phool For Your Fool"

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/phoolforyourfool?schema=public"

# --- Auth (JWT) ---
JWT_SECRET="replace-with-32-char-random-string"
JWT_EXPIRES_IN="30d"

# --- Cloudinary (primary media layer) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="phoolforyourfool_unsigned"
CLOUDINARY_UPLOAD_FOLDER="phoolforyourfool"

# --- Email (Gmail SMTP via App Password) ---
# 1. Enable 2-Step Verification on the Gmail account.
# 2. Visit https://myaccount.google.com/apppasswords and generate a 16-char App Password.
# 3. Paste below WITHOUT spaces.
GMAIL_USER="your.address@gmail.com"
GMAIL_APP_PASSWORD="abcdabcdabcdabcd"
GMAIL_FROM_NAME="Phool For Your Fool"
# Optional: notify the shop when a new order/bulk-quote arrives. Defaults to GMAIL_USER.
SHOP_NOTIFY_EMAIL=""

# --- Admin bootstrap (optional) ---
ADMIN_BOOTSTRAP_EMAIL="admin@phoolforyourfool.com"
ADMIN_BOOTSTRAP_PASSWORD="ChangeMeNow!2026"
